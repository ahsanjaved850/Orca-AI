{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,      
        "buildType": "development"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "buildType": "development" 
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "buildType": "archive" 
      }
    }
  },
  "submit": {
    "production": {}
  }
}